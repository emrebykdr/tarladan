@model IEnumerable<Order>
@{
    ViewData["Title"] = "Siparişlerim";
    var currentUserId = ViewBag.CurrentUserId as string;
}

<div class="page-header animated-fade-in">
    <div class="header-content">
        <h1><i class="fas fa-shopping-bag"></i> Siparişlerim</h1>
        <p>Tüm alım ve satım işlemlerinizin güncel durumu</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state animate-slide-up">
        <div class="empty-icon-wrapper">
             <i class="fas fa-shopping-basket"></i>
        </div>
        <h3>Henüz siparişiniz yok</h3>
        <p>Pazarlık sonucu kabul edilen teklifler burada siparişe dönüşür.</p>
        <a href="/" class="btn btn-primary btn-lg"><i class="fas fa-store"></i> Pazara Göz At</a>
    </div>
}
else
{
    <div class="order-list animate-slide-up">
        @foreach (var order in Model.OrderByDescending(o => o.CreatedAt))
        {
            var isSeller = order.SellerId == currentUserId;
            var otherParty = isSeller ? (order.Buyer?.FullName ?? "Alıcı") : (order.Seller?.FullName ?? "Satıcı");
            var statusText = order.Status switch
            {
                TarimPazari.Core.Enums.OrderStatus.Agreed => "Anlaşıldı",
                TarimPazari.Core.Enums.OrderStatus.Preparing => "Hazırlanıyor",
                TarimPazari.Core.Enums.OrderStatus.ReadyForPickup => "Teslimata Hazır",
                TarimPazari.Core.Enums.OrderStatus.Completed => "Tamamlandı",
                _ => order.Status.ToString()
            };
            var statusClass = order.Status switch
            {
                TarimPazari.Core.Enums.OrderStatus.Agreed => "status-agreed",
                TarimPazari.Core.Enums.OrderStatus.Preparing => "status-preparing",
                TarimPazari.Core.Enums.OrderStatus.ReadyForPickup => "status-ready",
                TarimPazari.Core.Enums.OrderStatus.Completed => "status-completed",
                _ => ""
            };

            <a href="/Order/Details/@order.Id" class="order-card @statusClass">
                <div class="order-img-wrapper">
                    <img src="@(order.Product?.ImageUrl ?? "/images/no-image.png")" class="order-img" alt="Ürün" />
                </div>
                
                <div class="order-info">
                    <div class="order-title-box">
                        <h3>@(order.Product?.Name ?? "Ürün")</h3>
                        <span class="badge @statusClass">@statusText</span>
                    </div>
                    <div class="order-meta">
                        <span><i class="fas fa-id-badge"></i> #@order.Id.ToString().Substring(0, 8)</span>
                        <span><i class="fas fa-user-circle"></i> @otherParty</span>
                        <span><i class="fas fa-calendar-alt"></i> @order.CreatedAt.ToString("dd.MM.yyyy")</span>
                    </div>
                </div>

                <div class="order-cta-box">
                    <div class="order-price">₺@order.TotalAmount.ToString("N2")</div>
                    <div class="btn-goto-detail">
                        <span>Detay</span>
                        <i class="fas fa-arrow-right"></i>
                    </div>
                </div>
            </a>
        }
    </div>
}
