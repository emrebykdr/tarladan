@model LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon-wrapper">
                <i class="fas fa-lock-open"></i>
            </div>
            <h2>Hoş Geldiniz</h2>
            <p>Devam etmek için hesabınıza giriş yapın</p>
        </div>

        <form asp-action="Login" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group-floating">
                <label asp-for="Email">E-posta Adresi</label>
                <div class="input-with-icon">
                    <i class="fas fa-envelope"></i>
                    <input asp-for="Email" class="form-control" placeholder="ornek@email.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group-floating">
                <label asp-for="Password">Şifre</label>
                <div class="input-with-icon">
                    <i class="fas fa-key"></i>
                    <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group checkbox-group">
                <label class="custom-checkbox">
                    <input asp-for="RememberMe" />
                    <span class="checkmark"></span>
                    @Html.DisplayNameFor(m => m.RememberMe)
                </label>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg">
                Giriş Yap <i class="fas fa-arrow-right"></i>
            </button>

            <div class="auth-footer">
                <span>Henüz bir hesabınız yok mu?</span>
                <a href="/Account/Register" class="footer-link">Hemen Kayıt Ol</a>
            </div>
        </form>
    </div>
</div>
