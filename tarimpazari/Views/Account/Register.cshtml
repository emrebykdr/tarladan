@model RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon-wrapper">
                <i class="fas fa-user-plus"></i>
            </div>
            <h2>Hesap Oluştur</h2>
            <p>Tarladan sofrana yolculuğa başla</p>
        </div>

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-row">
                <div class="form-group-floating">
                    <label asp-for="FullName">Ad Soyad</label>
                    <div class="input-with-icon">
                        <i class="fas fa-user"></i>
                        <input asp-for="FullName" class="form-control" placeholder="Adınız Soyadınız" />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div class="form-group-floating">
                    <label asp-for="Email">E-posta Adresi</label>
                    <div class="input-with-icon">
                        <i class="fas fa-envelope"></i>
                        <input asp-for="Email" class="form-control" placeholder="ornek@email.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group-floating">
                    <label asp-for="Password">Şifre</label>
                    <div class="input-with-icon">
                        <i class="fas fa-key"></i>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="form-group-floating">
                    <label asp-for="ConfirmPassword">Şifre Tekrar</label>
                    <div class="input-with-icon">
                        <i class="fas fa-check-double"></i>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group-floating">
                <label asp-for="RoleType">Üyelik Tipi</label>
                <div class="input-with-icon">
                    <i class="fas fa-users"></i>
                    <select asp-for="RoleType" class="form-control" id="roleSelect">
                        <option value="">-- Hesap türü seçiniz --</option>
                        <option value="@UserRoleType.Ciftci">🌾 Çiftçi (Satıcı)</option>
                        <option value="@UserRoleType.Alici">🛒 Alıcı</option>
                    </select>
                </div>
                <span asp-validation-for="RoleType" class="text-danger"></span>
            </div>

            <div class="form-row">
                <div class="form-group-floating">
                    <label asp-for="PhoneNumber">Telefon Numarası</label>
                    <div class="input-with-icon">
                        <i class="fas fa-phone"></i>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="0555 123 4567" />
                    </div>
                </div>
                <div class="form-group-floating">
                    <label asp-for="City">Şehir</label>
                    <div class="input-with-icon">
                        <i class="fas fa-city"></i>
                        <input asp-for="City" class="form-control" placeholder="Örn: Antalya" />
                    </div>
                </div>
            </div>

            <div id="farmerFields" style="display:none;" class="animated-fade-in">
                <div class="divider"><span>Çiftlik Bilgileri</span></div>
                <div class="form-row">
                    <div class="form-group-floating">
                        <label asp-for="FarmName">Çiftlik Adı</label>
                        <div class="input-with-icon">
                            <i class="fas fa-tractor"></i>
                            <input asp-for="FarmName" class="form-control" placeholder="Çiftliğinizin Adı" />
                        </div>
                    </div>
                    <div class="form-group-floating">
                        <label asp-for="FarmLocation">Çiftlik Konumu</label>
                        <div class="input-with-icon">
                            <i class="fas fa-map-marker-alt"></i>
                            <input asp-for="FarmLocation" class="form-control" placeholder="Köy/Mahalle" />
                        </div>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg">
                Hesabımı Oluştur <i class="fas fa-rocket"></i>
            </button>

            <div class="auth-footer">
                <span>Zaten bir hesabınız var mı?</span>
                <a href="/Account/Login" class="footer-link">Giriş Yap</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('roleSelect').addEventListener('change', function() {
            var farmerFields = document.getElementById('farmerFields');
            farmerFields.style.display = this.value == '@((int)UserRoleType.Ciftci)' ? 'block' : 'none';
        });
    </script>
}
