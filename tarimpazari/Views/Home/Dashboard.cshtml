@model DashboardViewModel
@{
    ViewData["Title"] = "Kontrol Paneli";
}

<div class="dashboard">
    <div class="dashboard-header animated-fade-in">
        <h1><i class="fas fa-tachometer-alt"></i> Hoş geldin, @Model.FullName!</h1>
        <span class="role-badge">@Model.UserRole</span>
    </div>

    <div class="stats-grid">
        @if (Model.UserRole == "Ciftci")
        {
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-box"></i></div>
                <div class="stat-info">
                    <h3>@Model.TotalProducts</h3>
                    <p>Toplam Ürün</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon orange"><i class="fas fa-clock"></i></div>
                <div class="stat-info">
                    <h3>@Model.PendingOffers</h3>
                    <p>Bekleyen Teklif</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue"><i class="fas fa-shopping-bag"></i></div>
                <div class="stat-info">
                    <h3>@Model.ActiveOrders</h3>
                    <p>Aktif Sipariş</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon pink"><i class="fas fa-envelope"></i></div>
                <div class="stat-info">
                    <h3>@Model.UnreadMessages</h3>
                    <p>Okunmamış Mesaj</p>
                </div>
            </div>
            <div class="stat-card action-card">
                <a href="/Product/Create"><i class="fas fa-plus-circle"></i> Yeni Ürün Ekle</a>
            </div>
            <div class="stat-card action-card">
                <a href="/Chat"><i class="fas fa-comments"></i> Sohbetler & Teklifler</a>
            </div>
            <div class="stat-card action-card">
                <a href="/Order"><i class="fas fa-shopping-bag"></i> Siparişlerim</a>
            </div>
        }
        else if (Model.UserRole == "Alici")
        {
            <div class="stat-card">
                <div class="stat-icon blue"><i class="fas fa-hand-holding-usd"></i></div>
                <div class="stat-info">
                    <h3>@Model.TotalOffers</h3>
                    <p>Tekliflerim</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-shopping-bag"></i></div>
                <div class="stat-info">
                    <h3>@Model.ActiveOrders</h3>
                    <p>Aktif Sipariş</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon pink"><i class="fas fa-envelope"></i></div>
                <div class="stat-info">
                    <h3>@Model.UnreadMessages</h3>
                    <p>Okunmamış Mesaj</p>
                </div>
            </div>
            <div class="stat-card action-card">
                <a href="/"><i class="fas fa-store"></i> Pazara Git</a>
            </div>
            <div class="stat-card action-card">
                <a href="/Chat"><i class="fas fa-comments"></i> Sohbetler & Teklifler</a>
            </div>
            <div class="stat-card action-card">
                <a href="/Order"><i class="fas fa-shopping-bag"></i> Siparişlerim</a>
            </div>
        }
        else if (Model.UserRole == "Admin")
        {
            <div class="stat-card">
                <div class="stat-icon green"><i class="fas fa-box"></i></div>
                <div class="stat-info">
                    <h3>@Model.TotalProducts</h3>
                    <p>Toplam Ürün</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon blue"><i class="fas fa-users"></i></div>
                <div class="stat-info">
                    <h3>@Model.TotalUsers</h3>
                    <p>Toplam Kullanıcı</p>
                </div>
            </div>
            <div class="stat-card action-card">
                <a href="/Admin"><i class="fas fa-users-cog"></i> Kullanıcı Yönetimi</a>
            </div>
            <div class="stat-card action-card">
                <a href="/Product"><i class="fas fa-box"></i> Ürün Yönetimi</a>
            </div>
            <div class="stat-card action-card">
                <a href="/Product/Create"><i class="fas fa-plus-circle"></i> Yeni Ürün Ekle</a>
            </div>
        }
    </div>
</div>
