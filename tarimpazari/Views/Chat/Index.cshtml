@model IEnumerable<Conversation>
@{
    ViewData["Title"] = "Mesajlarım";
    var currentUserId = ViewBag.CurrentUserId as string;
}

<div class="page-header animated-fade-in">
    <div class="header-content">
        <h1><i class="fas fa-comments"></i> Mesajlarım</h1>
        <p>Satıcılar ve alıcılar ile olan tüm görüşmeleriniz</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state animate-slide-up">
        <div class="empty-icon-wrapper">
            <i class="fas fa-comment-slash"></i>
        </div>
        <h3>Henüz mesajınız yok</h3>
        <p>Ürün detay sayfasından "Pazarlık Başlat" diyerek iletişime geçebilirsiniz.</p>
        <a href="/" class="btn btn-primary btn-lg"><i class="fas fa-shopping-basket"></i> Pazarı Keşfet</a>
    </div>
}
else
{
    <div class="chat-list animate-slide-up">
        @foreach (var conv in Model)
        {
            var isCurrentUserBuyer = conv.BuyerId == ViewBag.CurrentUserId?.ToString();
            var otherPartyName = isCurrentUserBuyer
                ? (conv.Seller?.FullName ?? "Satıcı")
                : (conv.Buyer?.FullName ?? "Alıcı");
            var productName = conv.Product?.Name ?? "Ürün";
            var lastMessage = conv.Messages?.OrderByDescending(m => m.SentAt).FirstOrDefault();
            var unreadCount = conv.Messages?.Count(m => m.SenderId != ViewBag.CurrentUserId?.ToString() && !m.IsRead) ?? 0;

            <a href="/Chat/Conversation/@conv.Id" class="chat-list-item @(unreadCount > 0 ? "is-unread" : "")">
                <div class="chat-item-avatar">
                    <div class="avatar-circle">
                         @otherPartyName.Substring(0, 1).ToUpper()
                    </div>
                </div>
                
                <div class="chat-item-main">
                    <div class="chat-item-header">
                        <span class="other-name">@otherPartyName</span>
                        @if (lastMessage != null)
                        {
                            <span class="chat-time">@lastMessage.SentAt.ToString("HH:mm")</span>
                        }
                    </div>
                    
                    <div class="chat-product-box">
                        <i class="fas fa-leaf"></i> @productName
                    </div>

                    @if (lastMessage != null)
                    {
                        <div class="chat-preview-text">
                            @if (lastMessage.SenderId == ViewBag.CurrentUserId?.ToString()) { <i class="fas fa-check-double sent-icon"></i> }
                            <span>@(lastMessage.Content.Length > 75 ? lastMessage.Content.Substring(0, 75) + "..." : lastMessage.Content)</span>
                        </div>
                    }
                </div>

                @if (unreadCount > 0)
                {
                    <div class="unread-indicator">
                        <span class="badge-dot"></span>
                        <span class="count">@unreadCount</span>
                    </div>
                }
                
                <div class="chat-item-chevron">
                    <i class="fas fa-chevron-right"></i>
                </div>
            </a>
        }
    </div>
}
