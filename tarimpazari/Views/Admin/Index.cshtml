@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="page-header">
    <h1><i class="fas fa-users-cog"></i> Kullanıcı Yönetimi</h1>
    <p style="color: var(--text-secondary); font-size: 0.88rem;">
        Toplam @Model.Count() kullanıcı |
        <span style="color: var(--green);">@Model.Count(u => !u.IsSuspended && !u.IsBanned) aktif</span> |
        <span style="color: #f59e0b;">@Model.Count(u => u.IsSuspended) askıda</span> |
        <span style="color: var(--danger);">@Model.Count(u => u.IsBanned) banlı</span>
    </p>
</div>

<div class="table-responsive">
    <table class="data-table">
        <thead>
            <tr>
                <th>Kullanıcı</th>
                <th>Rol</th>
                <th>Şehir</th>
                <th>Durum</th>
                <th>Yetkiler</th>
                <th>Kayıt</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var statusClass = user.IsBanned ? "banned" : user.IsSuspended ? "suspended" : "active";
                var statusText = user.IsBanned ? "🚫 Banlı" : user.IsSuspended ? "⏸️ Askıda" : "✅ Aktif";
                var isAdmin = user.RoleType.ToString() == "Admin";

                <tr class="user-row @statusClass">
                    <td>
                        <div class="user-cell">
                            <strong>@user.FullName</strong>
                            <small>@user.Email</small>
                        </div>
                    </td>
                    <td>
                        <span class="badge role-@user.RoleType.ToString().ToLower()">
                            @(user.RoleType.ToString() == "Ciftci" ? "🌾 Çiftçi" :
                              user.RoleType.ToString() == "Alici" ? "🛒 Alıcı" :
                              "👑 Admin")
                        </span>
                    </td>
                    <td>@(user.City ?? "—")</td>
                    <td>
                        <span class="badge status-@statusClass">@statusText</span>
                        @if (user.IsSuspended && !string.IsNullOrEmpty(user.SuspendReason))
                        {
                            <div class="status-reason"><i class="fas fa-info-circle"></i> @user.SuspendReason</div>
                        }
                        @if (user.IsBanned && !string.IsNullOrEmpty(user.BanReason))
                        {
                            <div class="status-reason"><i class="fas fa-info-circle"></i> @user.BanReason</div>
                        }
                    </td>
                    <td>
                        @if (user.RoleType.ToString() == "Ciftci")
                        {
                            <span class="perm-badge @(user.CanAddProducts ? "perm-yes" : "perm-no")">
                                <i class="fas @(user.CanAddProducts ? "fa-check" : "fa-times")"></i> Ürün Ekleme
                            </span>
                        }
                        else
                        {
                            <span style="color: var(--text-muted); font-size: 0.78rem;">—</span>
                        }
                    </td>
                    <td>@user.CreatedAt.ToString("dd.MM.yy")</td>
                    <td>
                        @if (!isAdmin)
                        {
                            <div class="admin-actions">
                                @* ASKIYA ALMA / ÇIKARMA *@
                                @if (!user.IsBanned)
                                {
                                    @if (user.IsSuspended)
                                    {
                                        <form asp-action="Unsuspend" asp-route-id="@user.Id" method="post" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success" title="Askıdan Çıkar">
                                                <i class="fas fa-play"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <div class="action-with-reason">
                                            <input type="text" form="suspendForm-@user.Id" name="reason"
                                                placeholder="Sebep..." class="reason-input" />
                                            <form asp-action="Suspend" asp-route-id="@user.Id" method="post"
                                                id="suspendForm-@user.Id" class="inline-form">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-warning" title="Askıya Al">
                                                    <i class="fas fa-pause"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                }

                                @* ÜRÜN EKLEME YETKİSİ *@
                                @if (user.RoleType.ToString() == "Ciftci" && !user.IsBanned)
                                {
                                    <form asp-action="ToggleProducts" asp-route-id="@user.Id" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(user.CanAddProducts ? "btn-outline" : "btn-primary")"
                                            title="@(user.CanAddProducts ? "Ürün Eklemeyi Kapat" : "Ürün Eklemeyi Aç")">
                                            <i class="fas @(user.CanAddProducts ? "fa-box" : "fa-box-open")"></i>
                                        </button>
                                    </form>
                                }

                                @* BAN / UNBAN *@
                                @if (user.IsBanned)
                                {
                                    <form asp-action="Unban" asp-route-id="@user.Id" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success" title="Yasağı Kaldır">
                                            <i class="fas fa-unlock"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <div class="action-with-reason">
                                        <input type="text" form="banForm-@user.Id" name="reason"
                                            placeholder="Ban sebebi..." class="reason-input" />
                                        <form asp-action="Ban" asp-route-id="@user.Id" method="post"
                                            id="banForm-@user.Id" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger" title="Banla"
                                                onclick="return confirm('Bu kullanıcıyı kalıcı olarak yasaklamak istediğinize emin misiniz?')">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <span style="color: var(--text-muted); font-size: 0.78rem;"><i class="fas fa-shield-alt"></i> Yönetici</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
